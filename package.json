{
  "name": "crm-multi-tenant",
  "version": "0.2.0",
  "description": "Multi-tenant CRM backend with Hono, Bun, TypeORM",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "migration:generate": "bunx typeorm migration:generate -d src/config/database.ts",
    "migration:run": "bunx typeorm migration:run -d src/config/database.ts",
    "migration:revert": "bunx typeorm migration:revert -d src/config/database.ts"
  },
  "dependencies": {
    "@google/adk": "^1.2.0",
    "@google/generative-ai": "^0.24.1",
    "@hono/swagger-ui": "^0.5.0",
    "@hono/zod-validator": "^0.4.0",
    "hono": "^4.7.0",
    "minio": "^8.0.0",
    "pg": "^8.16.0",
    "pgvector": "^0.3.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "uuid": "^11.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.8.0"
  }
}
